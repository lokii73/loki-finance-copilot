# ═══════════════════════════════════════════════════════════════
# Loki Finance Copilot — Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git
# ═══════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────
APP_NAME="Loki Finance Copilot"
APP_ENV=production           # development | production
DEBUG=False

# ── Security ───────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET_KEY_32_CHARS_MIN
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440   # 24 hours

# ── AI Provider ────────────────────────────────────────────────
# Options: openai | anthropic | mock (mock = keyword-based fallback, no API key needed)
AI_PROVIDER=mock
OPENAI_API_KEY=sk-REPLACE_IF_USING_OPENAI
ANTHROPIC_API_KEY=sk-ant-REPLACE_IF_USING_ANTHROPIC
AI_MODEL=gpt-4o-mini         # or claude-3-haiku-20240307

# ── Database (optional — only needed for Phase 2 real data) ───
# Leave as sqlite for local dev. Switch to postgresql for Supabase.
DATABASE_URL=sqlite:///./loki_finance.db
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/loki_finance

# ── CORS ───────────────────────────────────────────────────────
# In production, replace * with your Vercel domain
ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Angel One (Phase 2 — real market data) ────────────────────
# Leave blank until you integrate the Angel One Smart API
ANGEL_ONE_API_KEY=
ANGEL_ONE_CLIENT_ID=
ANGEL_ONE_PASSWORD=
ANGEL_ONE_TOTP_SECRET=
